{"openapi":"3.0.3","info":{"title":"jprint API","description":"Thermal receipt printer API - ESC/POS and ZPL via CUPS. Supports single jobs and batch printing.","version":"1.0.0"},"tags":[{"name":"Print","description":"Send jobs to printers"},{"name":"Preview","description":"Render to PNG (no printer)"},{"name":"Admin","description":"Printers and settings"}],"servers":[{"url":"/","description":"Current server"}],"paths":{"/api/printers":{"get":{"tags":["Admin"],"summary":"List printers","description":"Returns available CUPS printers","responses":{"200":{"description":"List of printer names","content":{"application/json":{"schema":{"type":"object","properties":{"printers":{"type":"array","items":{"type":"string"}}}}}}}}}},"/api/printers/status":{"get":{"tags":["Admin"],"summary":"Printer state and queues","description":"Returns CUPS printer state (e.g. idle, printing) and job queues for each printer.","responses":{"200":{"description":"Printers with state and queues","content":{"application/json":{"schema":{"type":"object","properties":{"printers":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string","description":"CUPS printer name"},"state":{"type":"string","description":"e.g. idle, printing"},"isDefault":{"type":"boolean","description":"Whether this is the system default destination"},"jobs":{"type":"array","items":{"type":"object","properties":{"id":{"type":"string","description":"Job ID"},"user":{"type":"string"},"size":{"type":"string"},"time":{"type":"string","description":"Job date/time from lpstat"}}}}}}}}}}}},"500":{"description":"Server or CUPS error","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"string"}}}}}}}}},"/api/settings":{"get":{"tags":["Admin"],"summary":"Get settings","responses":{"200":{"description":"Current printer settings","content":{"application/json":{"schema":{"type":"object","additionalProperties":true}}}}}},"put":{"tags":["Admin"],"summary":"Save settings","requestBody":{"content":{"application/json":{"schema":{"type":"object","additionalProperties":true}}}},"responses":{"200":{"description":"Settings saved","content":{"application/json":{"schema":{"type":"object","properties":{"ok":{"type":"boolean"}}}}}}}}},"/api/print/zpl":{"post":{"tags":["Print"],"summary":"Print ZPL","description":"Print ZPL label to CUPS printer. Provide either raw `zpl` or `template` + `data` (Handlebars).","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["printerName"],"properties":{"printerName":{"type":"string","example":"zebra-label"},"zpl":{"type":"string","description":"Raw ZPL string (use this OR template+data)","example":"^XA^FO50,50^ADN,36,20^FDHello World^FS^XZ"},"template":{"type":"string","description":"Handlebars template for ZPL (use with data instead of zpl)"},"data":{"type":"object","description":"Template data (required when using template)"}},"example":{"printerName":"zebra-label","zpl":"^XA^FO50,50^ADN,36,20^FDHello World^FS^XZ"}},"examples":{"raw":{"summary":"Raw ZPL","value":{"printerName":"zebra-label","zpl":"^XA^FO50,50^ADN,36,20^FDHello World^FS^XZ"}},"templated":{"summary":"ZPL with Handlebars","value":{"printerName":"zebra-label","template":"^XA^FO50,50^ADN,36,20^FD{{name}}^FS^XZ","data":{"name":"Order #42"}}}}}}},"responses":{"200":{"description":"Print job submitted","content":{"application/json":{"schema":{"type":"object","properties":{"ok":{"type":"boolean"},"job":{"type":"string"},"type":{"type":"string","enum":["zpl"]}}}}}},"400":{"description":"printerName required; zpl or (template and data) required"},"500":{"description":"Print error"}}}},"/api/print/escpos":{"post":{"tags":["Print"],"summary":"Print ESC/POS receipt","description":"Print receipt to CUPS printer. Uses ReceiptLine markup + Handlebars.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["printerName","template","data"],"properties":{"printerName":{"type":"string","example":"register"},"template":{"type":"string","example":"^^^** {{title}} **\n---\n^{{message}}\n==="},"data":{"type":"object","example":{"title":"Order","message":"Table 5 - 2 coffees"}},"receiptConfig":{"type":"object","example":{"cpl":48,"copies":1}}},"example":{"printerName":"register","template":"^^^** {{title}} **\n---\n^{{message}}\n===","data":{"title":"Order","message":"Table 5 - 2 coffees"}}},"examples":{"default":{"summary":"Receipt","value":{"printerName":"register","template":"^^^** {{title}} **\n---\n^{{message}}\n===","data":{"title":"Order","message":"Table 5 - 2 coffees"},"receiptConfig":{"cpl":48,"copies":1}}}}}}},"responses":{"200":{"description":"Print job submitted","content":{"application/json":{"schema":{"type":"object","properties":{"ok":{"type":"boolean"},"job":{"type":"string"},"type":{"type":"string","enum":["escpos"]}}}}}},"400":{"description":"printerName, template and data required"},"500":{"description":"Print error"}}}},"/api/print/escpos/raw":{"post":{"tags":["Print"],"summary":"Print raw ESC/POS","description":"Send base64-encoded ESC/POS data directly to a CUPS printer. No templating.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["printerName","data"],"properties":{"printerName":{"type":"string","example":"register"},"data":{"type":"string","description":"Base64-encoded ESC/POS bytes"}}}}}},"responses":{"200":{"description":"Print job submitted","content":{"application/json":{"schema":{"type":"object","properties":{"ok":{"type":"boolean"},"job":{"type":"string"},"type":{"type":"string","enum":["escpos-raw"]}}}}}},"400":{"description":"printerName and data required"},"500":{"description":"Print error"}}}},"/api/print/batch":{"post":{"tags":["Print"],"summary":"Print batch (bulk)","operationId":"printBatch","description":"Print multiple jobs (ESC/POS and/or ZPL) in one request. Jobs run sequentially. Partial failures return per-job results.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["jobs"],"properties":{"jobs":{"type":"array","minItems":1,"items":{"type":"object","required":["printerName"],"properties":{"type":{"type":"string","enum":["escpos","zpl"],"default":"escpos"},"printerName":{"type":"string","example":"registerfront"},"template":{"type":"string","description":"Handlebars template (required for escpos; optional for zpl with data)"},"data":{"type":"object","description":"Template data (required for escpos; optional for zpl with template)"},"zpl":{"type":"string","description":"Raw ZPL (alternative to template+data for zpl type)"},"receiptConfig":{"type":"object","description":"ReceiptLine config for escpos (cpl, copies, etc.)"}}}}},"example":{"jobs":[{"type":"escpos","printerName":"registerfront","template":"^^^** {{title}} **\n---\n^{{items}}\n===","data":{"title":"Order #42","items":"2x Coffee, 1x Croissant"}},{"type":"escpos","printerName":"registerfront","template":"^^^** {{title}} **\n---\n^{{items}}\n===","data":{"title":"Order #42","items":"2x Coffee, 1x Croissant"}}]}},"examples":{"escpos-only":{"summary":"Multiple receipts","value":{"jobs":[{"type":"escpos","printerName":"registerfront","template":"^^^** {{title}} **\n---\n^{{items}}\n===","data":{"title":"Order #42","items":"2x Coffee"}},{"type":"escpos","printerName":"registerfront","template":"^^^** {{title}} **\n---\n^{{items}}\n===","data":{"title":"Order #43","items":"1x Soup"}}]}},"mixed":{"summary":"Receipt + label","value":{"jobs":[{"type":"escpos","printerName":"registerfront","template":"^^^** {{title}} **\n===","data":{"title":"Order #42"}},{"type":"zpl","printerName":"zebra-label","template":"^XA^FO50,50^ADN,36,20^FD{{name}}^FS^XZ","data":{"name":"Order #42"}}]}}}}}},"responses":{"200":{"description":"Batch result (ok true if all succeeded, false if any failed)","content":{"application/json":{"schema":{"type":"object","properties":{"ok":{"type":"boolean","description":"True if all jobs succeeded"},"results":{"type":"array","items":{"oneOf":[{"type":"object","properties":{"ok":{"type":"boolean","const":true},"job":{"type":"string"},"type":{"type":"string","enum":["escpos","zpl"]},"index":{"type":"integer"}}},{"type":"object","properties":{"ok":{"type":"boolean","const":false},"error":{"type":"string"},"index":{"type":"integer"}}}]}}}}}}},"400":{"description":"jobs array required (non-empty)"}}}},"/api/print-dummy/zpl":{"post":{"tags":["Preview"],"summary":"ZPL to PNG","description":"Render ZPL as PNG (no printer)","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["zpl"],"properties":{"zpl":{"type":"string","example":"^XA^FO50,50^ADN,36,20^FDHello^FS^XZ"},"width_mm":{"type":"number","example":101.6},"height_mm":{"type":"number","example":203.2},"dpmm":{"type":"integer","example":8}},"example":{"zpl":"^XA^FO50,50^ADN,36,20^FDHello^FS^XZ"}},"examples":{"default":{"summary":"Simple ZPL","value":{"zpl":"^XA^FO50,50^ADN,36,20^FDHello^FS^XZ"}}}}}},"responses":{"200":{"description":"PNG image","content":{"image/png":{"schema":{"type":"string","format":"binary"}}}},"400":{"description":"zpl required"},"500":{"description":"Render error"}}}},"/api/print-dummy/escpos":{"post":{"tags":["Preview"],"summary":"Receipt to PNG","description":"Render receipt as PNG (no printer)","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["template","data"],"properties":{"template":{"type":"string","example":"^^^** {{title}} **\n---\n^{{message}}\n==="},"data":{"type":"object","example":{"title":"Test","message":"Hello from jprint"}},"receiptConfig":{"type":"object","example":{}}},"example":{"template":"^^^** {{title}} **\n---\n^{{message}}\n===","data":{"title":"Test","message":"Hello from jprint"}}},"examples":{"default":{"summary":"Receipt","value":{"template":"^^^** {{title}} **\n---\n^{{message}}\n===","data":{"title":"Test","message":"Hello from jprint"}}}}}}},"responses":{"200":{"description":"PNG image","content":{"image/png":{"schema":{"type":"string","format":"binary"}}}},"400":{"description":"template and data required"},"500":{"description":"Render error"}}}},"/api/preview":{"post":{"tags":["Preview"],"summary":"Receipt preview","description":"Render ESC/POS receipt as PNG (no printer)","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["template","data"],"properties":{"template":{"type":"string","example":"^^^** {{title}} **\n---\n^{{message}}\n==="},"data":{"type":"object","example":{"title":"Test","message":"Hello"}},"receiptConfig":{"type":"object","example":{}}},"example":{"template":"^^^** {{title}} **\n---\n^{{message}}\n===","data":{"title":"Test","message":"Hello"}}},"examples":{"default":{"summary":"Receipt","value":{"template":"^^^** {{title}} **\n---\n^{{message}}\n===","data":{"title":"Test","message":"Hello"}}}}}}},"responses":{"200":{"description":"PNG image","content":{"image/png":{"schema":{"type":"string","format":"binary"}}}}}}},"/api/zpl-preview":{"post":{"tags":["Preview"],"summary":"ZPL preview","description":"Render ZPL label as PNG (via ZPL_PREVIEW_URL)","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["zpl"],"properties":{"zpl":{"type":"string","example":"^XA^FO50,50^ADN,36,20^FDHello^FS^XZ"},"width_mm":{"type":"number","example":101.6},"height_mm":{"type":"number","example":203.2},"dpmm":{"type":"integer","example":8}},"example":{"zpl":"^XA^FO50,50^ADN,36,20^FDHello^FS^XZ","width_mm":101.6,"height_mm":203.2,"dpmm":8}},"examples":{"default":{"summary":"4x6 label","value":{"zpl":"^XA^FO50,50^ADN,36,20^FDHello^FS^XZ","width_mm":101.6,"height_mm":203.2,"dpmm":8}}}}}},"responses":{"200":{"description":"PNG image","content":{"image/png":{"schema":{"type":"string","format":"binary"}}}}}}}}}